# Copier ce fichier en ".env" et remplir avec vos vraies valeurs

PORT=3000

# Convertit le rapport en PDF avant envoi (nécessite LibreOffice installé sur le serveur — voir DEPLOIEMENT.md)
CONVERT_TO_PDF=false

# Adresse du cabinet qui reçoit une copie (bcc) de chaque rapport envoyé
CABINET_EMAIL=contact@prestigecenterconsulting.bj

# Paramètres SMTP pour l'envoi d'email (exemple avec Gmail : smtp.gmail.com, port 587,
# nécessite un "mot de passe d'application" Google, pas votre mot de passe habituel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-adresse@gmail.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM=votre-adresse@gmail.com

# --- Paiement CinetPay ---
# Identifiants fournis par CinetPay après création d'un compte marchand (cinetpay.com)
CINETPAY_APIKEY=votre_apikey_cinetpay
CINETPAY_SITE_ID=votre_site_id_cinetpay

# Prix du Legal Check-up PME en FCFA (doit être un multiple de 5)
CHECKUP_PRICE_FCFA=15000

# URL de votre formulaire Tally (le lien envoyé au client après paiement)
TALLY_FORM_URL=https://tally.so/r/VOTRE_FORMULAIRE

# URL publique de ce serveur une fois déployé (ex: https://legal-checkup.onrender.com)
# Utilisée pour construire notify_url et return_url envoyés à CinetPay
BASE_URL=https://votre-app.onrender.com

# Mettre à "false" uniquement pour tester le questionnaire sans paiement
REQUIRE_PAYMENT=true
